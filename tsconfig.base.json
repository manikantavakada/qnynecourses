{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@qnyne/database": ["packages/database/src"],
      "@qnyne/database/*": ["packages/database/src/*"],
      "@qnyne/shared": ["packages/shared/src"],
      "@qnyne/shared/*": ["packages/shared/src/*"]
    }
  }
}
