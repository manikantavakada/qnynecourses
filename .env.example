DATABASE_URL="postgresql://user:password@localhost:5432/course_platform?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_ACCESS_SECRET="replace-with-strong-access-secret"
JWT_REFRESH_SECRET="replace-with-strong-refresh-secret"
VIDEO_TOKEN_SECRET="replace-with-strong-video-secret"

# Object storage - S3-compatible (Backblaze B2, Cloudflare R2, AWS S3, etc.)
STORAGE_ENDPOINT=""
STORAGE_REGION=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET_NAME=""

# Public URL of this API (used to build video stream URLs when CF_WORKER_STREAM_URL is unset)
API_PUBLIC_URL="http://localhost:4000"

# Optional: only set once you're on Cloudflare Workers + R2. Leave blank to
# stream videos straight from this API instead (apps/api/src/modules/stream).
CF_WORKER_STREAM_URL=""

RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""
EMAIL_PROVIDER_API_KEY=""
EMAIL_FROM="Qnyne <no-reply@yourdomain.com>"
